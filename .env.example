# Example environment variables for techyardsystems-redesign.
# Copy to `.env.local` and fill in real values for local development.
# Do NOT commit `.env.local` (ignored by .gitignore).

# Public site URL used for canonical links, sitemap, and OG metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Plausible analytics domain (as registered in the Plausible dashboard).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=techyardsystems.com

# Calendly embed URL used by the ContactSidebar lazy-loader.
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/rubal-techyardsystems/15-min-quick-query-call

# Resend API key (server-only). The Contact form server action uses this.
RESEND_API_KEY=
RESEND_FROM_EMAIL=contactus@techyardsystems.com
CONTACT_TO_EMAIL=contactus@techyardsystems.com
